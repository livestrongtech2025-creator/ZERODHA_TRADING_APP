    import datetime as dt
import pandas as pd
from kiteconnect import KiteConnect
from concurrent.futures import ThreadPoolExecutor
from Nifty5X_margin import stocks

# ---------------- CONFIG ---------------- #
from config import ZERODHA_API_KEY, ZERODHA_ACCESS_TOKEN
kite = KiteConnect(api_key=ZERODHA_API_KEY)
kite.set_access_token(ZERODHA_ACCESS_TOKEN)

# Pre-fetch instrument tokens (For Ultra-Speed)
all_ins = kite.instruments("NSE")
token_map = {i['tradingsymbol']: i['instrument_token'] for i in all_ins if i['tradingsymbol'] in stocks}

def get_accurate_setup(symbol):
    try:
        token = token_map.get(symbol)
        if not token: return None

        today = dt.datetime.now().date()
        # Scan range: Opening to current time (ideally run this at 11:00 AM)
        data = kite.historical_data(token, dt.datetime.combine(today, dt.time(9, 15)), dt.datetime.now(), "5minute")
        df = pd.DataFrame(data)
        if len(df) < 15: return None

        # 1. Calculate VWAP (The Institutional Anchor)
        df['tp'] = (df['high'] + df['low'] + df['close']) / 3
        vwap = (df['tp'] * df['volume']).sum() / df['volume'].sum()
        
        last_price = df['close'].iloc[-1]
        day_open = df['open'].iloc[0]
        day_high = df['high'].max()
        day_low = df['low'].min()
        
        # 2. Institutional Filter: Relative Volume (Is it real money?)
        # We look for stocks where the 1st hour volume is > 50% of the PREVIOUS DAY'S total.
        prev_day = kite.historical_data(token, today - dt.timedelta(days=5), today - dt.timedelta(days=1), "day")
        avg_vol = pd.DataFrame(prev_day)['volume'].mean()
        rvol = df['volume'].sum() / avg_vol

        # 3. The "Smart Entry" Logic (70% Win Rate Filter)
        # Instead of buying the High, we buy when price is within 0.3% of VWAP after a breakout.
        side = None
        if last_price > vwap and last_price > day_open and rvol > 1.5:
            # Check for PULLBACK: Price is above VWAP but currently cooling off from the high
            if (last_price - vwap) / vwap < 0.005: # Within 0.5% of VWAP
                side = "BUY"
        elif last_price < vwap and last_price < day_open and rvol > 1.5:
            if (vwap - last_price) / vwap < 0.005:
                side = "SELL"

        if not side: return None

        return {
            "Symbol": symbol, "Side": side, "Entry": round(last_price, 2),
            "SL": round(vwap * 0.995, 2) if side == "BUY" else round(vwap * 1.005, 2),
            "Target": round(last_price * 1.02, 2) if side == "BUY" else round(last_price * 0.98, 2),
            "RVOL": round(rvol, 2)
        }
    except: return None

def main():
    print("Searching for Institutional Pullbacks (The 'Second Wave')...")
    with ThreadPoolExecutor(max_workers=50) as executor:
        results = list(filter(None, executor.map(get_accurate_setup, stocks)))

    buys = sorted([r for r in results if r['Side'] == 'BUY'], key=lambda x: x['RVOL'], reverse=True)[:15]
    sells = sorted([r for r in results if r['Side'] == 'SELL'], key=lambda x: x['RVOL'], reverse=True)[:15]

    print("\n--- TOP 15 LONG (HEDGED) ---\n", pd.DataFrame(buys))
    print("\n--- TOP 15 SHORT (HEDGED) ---\n", pd.DataFrame(sells))

if __name__ == "__main__":
    main()